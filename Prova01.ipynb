    "a = int(input(\"Digite um valor positivo:\"))\n",
    "b = int(input(\"Digite um valor positivo:\"))\n",
    "c = int(input(\"Digite um valor positivo:\"))\n",
    "\n",
    "print(a, b, c)\n",
    "\n",
    "if a <= b and a <= c:\n",
    "    print((b + c) / 2)\n",
    "elif b <= a and b <= c:\n",
    "    print((a + c) / 2)\n",
    "else:\n",
    "    print((a + b) / 2)"
